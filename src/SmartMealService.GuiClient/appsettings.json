{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=smart_meal_service_variables.db"
  },
  "EnvironmentVariables": [
    "PATH",
    "TEMP",
    "USERNAME",
    "CUSTOM_VARIABLE_1",
    "CUSTOM_VARIABLE_2"
  ],
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/test-sms-wpf-app-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}